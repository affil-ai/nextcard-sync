{
  "manifest_version": 3,
  "incognito": "split",
  "name": "nextcard sync",
  "short_name": "nextcard sync",
  "version": "0.4.6",
  "description": "Sync your loyalty program balances and credit card benefit usage to your nextcard wallet.",
  "permissions": [
    "storage",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://www.marriott.com/*",
    "https://www.alaskaair.com/*",
    "https://*.chase.com/*",
    "https://ultimaterewardspoints.chase.com/*",
    "https://secure.chase.com/*",
    "https://www.aa.com/*",
    "https://login.aa.com/*",
    "https://www.delta.com/*",
    "https://www.united.com/*",
    "https://www.southwest.com/*",
    "https://www.ihg.com/*",
    "https://www.hyatt.com/*",
    "https://global.americanexpress.com/*",
    "https://www.americanexpress.com/*",
    "https://americanexpress.com/*",
    "https://myaccounts.capitalone.com/*",
    "https://verified.capitalone.com/*",
    "https://travel.capitalone.com/*",
    "https://www.hilton.com/*",
    "https://booking.flyfrontier.com/*",
    "https://www.bilt.com/*",
    "https://www.biltrewards.com/*",
    "https://laudable-turtle-546.convex.site/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://nextcard.com/*",
      "https://*.nextcard.com/*"
    ]
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/marriott.ts-loader-V3LFxqcy.js"
      ],
      "matches": [
        "https://www.marriott.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/atmos.ts-loader-D9VI26On.js"
      ],
      "matches": [
        "https://www.alaskaair.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/chase.ts-loader-gl0uZi0g.js"
      ],
      "matches": [
        "https://ultimaterewardspoints.chase.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/chase-benefits.ts-loader-s8pwfNub.js"
      ],
      "matches": [
        "https://secure.chase.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
