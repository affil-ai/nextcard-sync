      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/icons/*.png"
      ],
      "use_dynamic_url": false
    },
